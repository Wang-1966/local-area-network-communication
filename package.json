{
  "name": "lan-messaging-app",
  "version": "1.0.0",
  "description": "LAN Messaging Application - Monorepo",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client",
    "dev:server": "npm run start:dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build:server": "npm run build --prefix server",
    "build:client": "npm run build --prefix client",
    "build": "npm run build:client && npm run build:server",
    "start": "npm run start:prod --prefix server",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "prod": "npm run build && npm start",
    "test:server": "npm test --prefix server",
    "test:client": "npm test --prefix client",
    "test": "npm run test:server && npm run test:client"
  },
  "keywords": ["lan", "messaging", "websocket", "nestjs", "react"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
